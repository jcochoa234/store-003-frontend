{
  "$schema": "http://json.schemastore.org/template",
  "author": "Store 003",
  "classifications": ["SPA", "Angular", "Frontend"],
  "identity": "PinnacleProjects.SsTemplateFrontend",
  "name": "Pinnacle Angular SPA Template",
  "shortName": "ss-frontend",
  "description": "Enterprise Angular 18 SPA — Vertical Slice Architecture, CQRS, NG-Zorro, Keycloak",
  "tags": {
    "language": "TypeScript",
    "type": "project"
  },
  "sourceName": "Store003Frontend",
  "preferNameDirectory": true,
  "symbols": {
    "title": {
      "type": "parameter",
      "datatype": "string",
      "defaultValue": "My Application",
      "description": "Application title used throughout the app (browser tab, page titles, layout)",
      "replaces": "Store 003"
    }
  },
  "sources": [
    {
      "exclude": [
        "node_modules/**",
        "dist/**",
        ".git/**",
        ".worktrees/**",
        "docs/superpowers/**"
      ]
    }
  ]
}
